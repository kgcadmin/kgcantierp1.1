# -------------------------------------------------------------
# KGC ERP - Environment Variables
# -------------------------------------------------------------

# 1. RESEND API KEY
# Create a free account at resend.com to generate your API Key
RESEND_API_KEY=re_YOUR_RESEND_API_KEY_HERE

# 2. FROM EMAIL ADDRESS
# This must be an email on the domain you verified with Resend.
# If you are in the testing phase, use Resend's default onboarding email:
# FROM_EMAIL="Acme <onboarding@resend.dev>"
FROM_EMAIL="Admin <admin@yourcollege.edu>"

# 3. BACKEND PORT (Optional, defaults to 5000)
PORT=5000
